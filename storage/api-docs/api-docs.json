{
    "openapi": "3.0.0",
    "info": {
        "title": "Hall Booking API",
        "version": "1.0.0",
        "description": "API for managing hall bookings and reservations"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000",
            "description": "Local Development Server"
        }
    ],
    "components": {
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "token"
            }
        }
    },
    "paths": {
        "/api/status": {
            "get": {
                "tags": ["System"],
                "summary": "Check API status",
                "operationId": "checkStatus",
                "responses": {
                    "200": {
                        "description": "API is running"
                    }
                }
            }
        },
        "/api/register": {
            "post": {
                "tags": ["Authentication"],
                "summary": "User Registration",
                "operationId": "register",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "password_confirmation",
                                    "role"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "John Doe"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "john@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password123"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password123"
                                    },
                                    "role": {
                                        "type": "string",
                                        "enum": ["admin", "owner", "customer"],
                                        "example": "customer"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "User registered successfully"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/login": {
            "post": {
                "tags": ["Authentication"],
                "summary": "User Login",
                "operationId": "login",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["email", "password"],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "john@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password123"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful"
                    },
                    "401": {
                        "description": "Invalid credentials"
                    }
                }
            }
        },
        "/api/logout": {
            "post": {
                "tags": ["Authentication"],
                "summary": "User Logout",
                "operationId": "logout",
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Logout successful"
                    }
                }
            }
        },
        "/api/delete-account": {
            "delete": {
                "tags": ["Authentication"],
                "summary": "Delete user account",
                "operationId": "deleteAccount",
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Account deleted successfully"
                    }
                }
            }
        },
        "/api/halls": {
            "get": {
                "tags": ["Halls"],
                "summary": "Get all halls",
                "operationId": "getAllHalls",
                "responses": {
                    "200": {
                        "description": "List of all halls"
                    }
                }
            },
            "post": {
                "tags": ["Halls"],
                "summary": "Create new hall",
                "operationId": "createHall",
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "location": {
                                        "type": "string"
                                    },
                                    "capacity": {
                                        "type": "integer"
                                    },
                                    "price_per_hour": {
                                        "type": "number"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Hall created successfully"
                    }
                }
            }
        },
        "/api/check-availability": {
            "get": {
                "tags": ["Bookings"],
                "summary": "Check hall availability",
                "operationId": "checkAvailability",
                "parameters": [
                    {
                        "name": "hall_id",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "start_date",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "date-time"
                        }
                    },
                    {
                        "name": "end_date",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "date-time"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Availability check result"
                    }
                }
            }
        },
        "/api/bookings": {
            "post": {
                "tags": ["Bookings"],
                "summary": "Create new booking",
                "operationId": "createBooking",
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "hall_id",
                                    "start_date",
                                    "end_date"
                                ],
                                "properties": {
                                    "hall_id": {
                                        "type": "integer"
                                    },
                                    "start_date": {
                                        "type": "string",
                                        "format": "date-time"
                                    },
                                    "end_date": {
                                        "type": "string",
                                        "format": "date-time"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Booking created successfully"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/bookings/{id}/confirm": {
            "post": {
                "tags": ["Bookings"],
                "summary": "Confirm booking payment",
                "operationId": "confirmPayment",
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Payment confirmed"
                    }
                }
            }
        },
        "/api/owner/block-date": {
            "post": {
                "tags": ["Bookings"],
                "summary": "Block date for hall",
                "operationId": "blockDate",
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "hall_id",
                                    "start_date",
                                    "end_date"
                                ],
                                "properties": {
                                    "hall_id": {
                                        "type": "integer"
                                    },
                                    "start_date": {
                                        "type": "string",
                                        "format": "date-time"
                                    },
                                    "end_date": {
                                        "type": "string",
                                        "format": "date-time"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Date blocked successfully"
                    }
                }
            }
        },
        "/api/my-bookings": {
            "get": {
                "tags": ["Bookings"],
                "summary": "Get customer's bookings",
                "operationId": "customerBookings",
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of customer bookings"
                    }
                }
            }
        },
        "/api/owner/bookings": {
            "get": {
                "tags": ["Bookings"],
                "summary": "Get owner's bookings",
                "operationId": "ownerBookings",
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of owner bookings"
                    }
                }
            }
        }
    }
}
